{
  "name": "tangent-cc-lib",
  "version": "0.0.22",
  "description": "Tangent CC Lib is a shared TypeScript library that collects the shared things across Tangent's several CharaChorder side projects.",
  "homepage": "https://github.com/andy23512/tangent-cc-lib",
  "bugs": {
    "url": "https://github.com/andy23512/tangent-cc-lib/issues",
    "email": "andy23512@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andy23512/tangent-cc-lib.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@tangent-cc-lib/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "rxjs": "~7.8.0"
  }
}
